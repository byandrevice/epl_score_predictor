PORT=5001
MONGO_URI=your mongodb string
JWT_SECRET=your_jwt_secret
CLIENT_URL=http://localhost:5173

# --- Email (SMTP) ---

# Gmail:            EMAIL_HOST=smtp.gmail.com        EMAIL_PORT=587
#   Gmail blocks your normal password — you need a 16-char "App Password":
#   Google Account -> Security -> 2-Step Verification (must be on) -> App Passwords
#
# Outlook/Office365: EMAIL_HOST=smtp.office365.com    EMAIL_PORT=587
#   Same idea — if 2FA is on, generate an "App Password" in Microsoft account security settings.
# Any other provider (school SMTP, SendGrid, Mailgun, etc.): use the host/port they give you.
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your_email_username
EMAIL_PASS=your_email_password
EMAIL_FROM=no-reply@example.com