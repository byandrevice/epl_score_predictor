# Base URL for the backend API. Copy this file to .env and fill in a real value.
#
# Local testing (physical phone via Expo Go, same Wi-Fi as your computer):
#   Find your LAN IP with `ipconfig getifaddr en0` (Mac) and use that.
#   Restart `npx expo start` after changing this — env vars aren't hot-reloaded.
EXPO_PUBLIC_API_URL=http://192.168.1.100:5001/api
